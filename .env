# Replace placeholder values before running the service.

# Gmail App Password for account: harshgour8909@gmail.com
# (Do NOT use your normal Gmail login password)
EMAIL_PASSWORD=replace_with_your_16_char_gmail_app_password

# API key protection toggle
# true  -> require X-API-KEY header on /api/v1/email/* endpoints
# false -> disable API-key auth
API_KEY_ENABLED=true

# Expected value for incoming X-API-KEY header when API_KEY_ENABLED=true
EMAIL_SERVICE_API_KEY=email-svc-dev-key-9f3c2b7a
